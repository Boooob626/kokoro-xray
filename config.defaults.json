{
  "version": "0.2.0",
  "language": "auto",
  "role": "",
  "inbound": {
    "mode": "both",
    "reality": {
      "dest": "www.cloudflare.com:443",
      "server_names": ["www.cloudflare.com"]
    },
    "tls": {
      "domain": "",
      "cdn_domain": "",
      "acme_email": ""
    },
    "xhttp": {
      "mode": "auto",
      "obfs": false,
      "xmux": false,
      "socket": true,
      "socket_path": "/run/kokoro-xray/xhttp.sock"
    }
  },
  "fallback": {
    "type": "static",
    "root": "/var/www/kokoro-fallback",
    "proxy_url": ""
  },
  "caddy": {
    "version": "2.9.1",
    "use_l4": true
  },
  "multinode": {
    "enabled": false,
    "exit_ip": "",
    "exit_port": 0,
    "peer_exit_pubkey": "",
    "peer_edge_pubkey": "",
    "local_wg_ip": "10.66.0.2",
    "peer_wg_ip": "10.66.0.1",
    "finalmask": false
  },
  "tor": {
    "enabled": false,
    "socks_port": 9050
  },
  "routing": {},
  "firewall": {
    "enabled": true,
    "ssh_port": 0,
    "extra_allow": []
  },
  "paths": {
    "xray_config": "/usr/local/etc/xray/config.json",
    "caddyfile": "/etc/caddy/Caddyfile",
    "xray_bin": "/usr/local/bin/xray",
    "caddy_bin": "/usr/local/bin/caddy",
    "geo_dir": "/usr/local/share/xray"
  }
}
