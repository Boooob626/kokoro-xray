{
  "outbounds": [
    {
      "tag": "WG_TO_EXIT",
      "protocol": "wireguard",
      "settings": {
        "secretKey": "{{WG_PRIVKEY}}",
        "address": ["{{LOCAL_WG_IP}}/32"],
        "peers": [
          {
            "publicKey": "{{PEER_PUBKEY}}",
            "endpoint": "{{PEER_ENDPOINT}}",
            "allowedIPs": ["0.0.0.0/0", "::/0"]
          }
        ]
      }
    }
  ]
}